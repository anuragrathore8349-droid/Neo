# NeoFin Trading Platform - Client Environment Configuration
# Copy this file to .env.local and fill in your actual values

# ============================================================
# API CONFIGURATION
# ============================================================

# Backend API URL
VITE_API_URL=https://api.neofintrading.com
VITE_API_TIMEOUT=30000

# WebSocket URL for real-time updates
VITE_WS_URL=wss://api.neofintrading.com

# ============================================================
# AUTHENTICATION
# ============================================================

# JWT Configuration
VITE_JWT_STORAGE_KEY=auth_token
VITE_REFRESH_TOKEN_KEY=refresh_token

# Session configuration
VITE_SESSION_TIMEOUT_MS=900000  # 15 minutes

# ============================================================
# WEB3 & WALLET
# ============================================================

# Ethereum network configuration
VITE_ETH_NETWORK=mainnet
VITE_ETH_CHAIN_ID=1

# Supported blockchain networks for wallet connection
VITE_SUPPORTED_CHAINS=1,137,42161,10,8453,56

# ============================================================
# MARKET DATA & TRADING
# ============================================================

# Default trading pair for charts
VITE_DEFAULT_SYMBOL=BTC/USD

# Default candlestick interval
VITE_DEFAULT_INTERVAL=1d

# Refresh interval for price updates (milliseconds)
VITE_PRICE_REFRESH_INTERVAL=5000

# Enable demo/paper trading mode by default
VITE_DEFAULT_TRADING_MODE=paper  # Options: paper, real

# ============================================================
# UI & THEME
# ============================================================

# Application theme (light or dark)
VITE_THEME=dark

# Enable dark mode
VITE_ENABLE_DARK_MODE=true

# Application locale
VITE_LOCALE=en-US

# ============================================================
# FEATURE FLAGS
# ============================================================

# Enable/disable features on frontend
VITE_ENABLE_REAL_TRADING=false
VITE_ENABLE_DEFI=true
VITE_ENABLE_AI_INSIGHTS=true
VITE_ENABLE_LEARNING_CENTER=true
VITE_ENABLE_PORTFOLIO_EXPORT=true
VITE_ENABLE_ALERTS=true

# ============================================================
# ANALYTICS & TRACKING
# ============================================================

# Google Analytics
VITE_GA_ID=G-XXXXXXXXXX

# Hotjar for heatmaps
VITE_HOTJAR_ID=3123456

# Mixpanel for event tracking
VITE_MIXPANEL_TOKEN=your-mixpanel-token

# ============================================================
# DEVELOPMENT
# ============================================================

# Enable debug logging in console
VITE_DEBUG_MODE=false

# API mock mode (for offline development)
VITE_MOCK_API=false

# Enable React Strict Mode
VITE_REACT_STRICT_MODE=true

# ============================================================
# PERFORMANCE
# ============================================================

# Enable service worker and offline support
VITE_ENABLE_PWA=true

# Chart points limit (for performance)
VITE_MAX_CHART_POINTS=500

# WebSocket reconnect attempts
VITE_WS_RECONNECT_ATTEMPTS=5

# WebSocket reconnect interval (milliseconds)
VITE_WS_RECONNECT_INTERVAL=3000
